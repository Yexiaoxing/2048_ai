{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://2048-ai.local/schemas/evaluation-single-move-cli-config.schema.json",
    "title": "2048 Single Move Evaluator Config",
    "description": "Configuration for packages/evaluation-single-move-cli/src/cli.ts",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "models": {
            "description": "Models to evaluate. If omitted, built-in defaults are used.",
            "type": "array",
            "items": {
                "$ref": "#/$defs/modelConfig"
            },
            "minItems": 1
        },
        "datasetPath": {
            "description": "Path to the dataset JSON array.",
            "type": "string",
            "minLength": 1,
            "default": "dataset/output/game_states.json"
        },
        "labelField": {
            "description": "Primary field used to read the expected move from each dataset row.",
            "type": "string",
            "minLength": 1,
            "default": "bestMoveExpectimax"
        },
        "limit": {
            "description": "Maximum number of samples to evaluate.",
            "type": "integer",
            "minimum": 1,
            "default": 200
        },
        "shuffle": {
            "description": "Shuffle the dataset before slicing by limit.",
            "type": "boolean",
            "default": false
        },
        "resultsFile": {
            "description": "Path to write evaluation results JSON.",
            "type": "string",
            "minLength": 1,
            "default": "results/single_move_eval_results.json"
        }
    },
    "$defs": {
        "modelConfig": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "name",
                "type"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Display name for reporting."
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "ollama",
                        "openai"
                    ]
                },
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Ollama model path/tag. If omitted, name is used."
                },
                "apiModelName": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Remote model name sent to the OpenAI-compatible endpoint."
                },
                "baseUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "OpenAI-compatible base URL (default: https://api.openai.com/v1)."
                },
                "apiKey": {
                    "type": "string",
                    "minLength": 1,
                    "description": "API key. Optional if OPENAI_API_KEY environment variable is set."
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "ollama"
                            }
                        },
                        "required": [
                            "type"
                        ]
                    },
                    "then": {
                        "not": {
                            "anyOf": [
                                {
                                    "required": [
                                        "apiModelName"
                                    ]
                                },
                                {
                                    "required": [
                                        "baseUrl"
                                    ]
                                },
                                {
                                    "required": [
                                        "apiKey"
                                    ]
                                }
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "openai"
                            }
                        },
                        "required": [
                            "type"
                        ]
                    },
                    "then": {
                        "not": {
                            "required": [
                                "path"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
