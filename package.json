{
    "name": "2048-ai-monorepo",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "pnpm --filter @2048/web dev",
        "dev:all": "pnpm -r --parallel --if-present dev",
        "build": "pnpm -r --if-present build",
        "test": "pnpm -r --if-present test",
        "test-ci": "pnpm -r --if-present test-ci",
        "typecheck": "pnpm -r --if-present typecheck",
        "lint": "biome check && pnpm -r --if-present typecheck",
        "lint:fix": "biome check --write",
        "storybook": "pnpm --filter @2048/web storybook",
        "build-storybook": "pnpm --filter @2048/web build-storybook",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "pnpm -r --if-present biome check --write --no-errors-on-unmatched"
        ]
    }
}
